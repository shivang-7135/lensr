# --- Frontend Environment Variables ---
# Copy this file to .env and fill in real values.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend connection (required for search to work)
BACKEND_BASE_URL=http://localhost:8000
BACKEND_SHARED_SECRET=generate-a-strong-random-secret-here

# CORS allowed origins (comma-separated, for the /api/search proxy)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com
